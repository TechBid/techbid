# ==============================
# App Runtime
# ==============================
FLASK_SECRET=replace-with-long-random-secret
APP_BASE_URL=http://127.0.0.1:5000
SERVER_NAME=localhost:5000
PREFERRED_URL_SCHEME=http
PORT=5000
WAITRESS_THREADS=16

# ==============================
# MySQL (REQUIRED)
# ==============================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=your_db_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_SSL_CA=
MYSQL_SSL_DISABLED=true
MYSQL_CONNECT_TIMEOUT=10
MYSQL_USE_POOL=false
DB_TABLE_PREFIX=tbm_

# ==============================
# Google OAuth (REQUIRED for login)
# ==============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback

# ==============================
# Paystack (KES — for Kenyan clients)
# ==============================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=http://127.0.0.1:5000/billing/paystack/callback
PAYSTACK_CURRENCY=KES

# ==============================
# Pesapal (KES — for international clients)
# ==============================
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=http://127.0.0.1:5000/billing/pesapal/callback
PESAPAL_IPN_URL=http://127.0.0.1:5000/api/payments/pesapal/ipn
PESAPAL_CURRENCY=KES
PESAPAL_API_URL=https://pay.pesapal.com/v3

# ==============================
# Currency Conversion
# ==============================
USD_TO_KES=130

# ==============================
# Gemini AI (Job Generator)
# ==============================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Max AI-generated jobs per daily run (to control token usage)
AI_JOBS_PER_RUN=10

# ==============================
# GitHub (Profile Picture Storage)
# ==============================
GITHUB_TOKEN=
GITHUB_REPO=your-username/your-repo-name
GITHUB_BRANCH=main

# ==============================
# SMTP (Email Notifications)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=techbidmarketplace@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=techbidmarketplace@gmail.com
SMTP_USE_TLS=true

# ==============================
# Admin Access
# ==============================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-securely

# Comma-separated Google emails that auto-get admin access
ADMIN_GOOGLE_EMAILS=your-admin@gmail.com
